        <mxCell id="GYHfwP5nTr4zkCVt0_hk-1" parent="GYHfwP5nTr4zkCVt0_hk-5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;" value="阿基米德&lt;br&gt;沐浴时专注于清洁皮肤和头发&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;+1 日常未洗手避免接触脸部皮肤&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="20" y="120" as="geometry" />
