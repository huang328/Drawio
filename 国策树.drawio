        <mxCell id="52FGgfgPVEXHtjKeg9y8-1" parent="IpGJSZYHcnI9OjIyq8Mq-8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;" value="风险规避&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;使用信号来在冲动行事前三思&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;+ 1 五指合三下冷静5min转做其他事&lt;/span&gt;&lt;/div&gt;" vertex="1">
