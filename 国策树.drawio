        <mxCell id="W8aSpgX1gb-iDZ2opPZD-1" parent="IpGJSZYHcnI9OjIyq8Mq-8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;" value="整顿内务&lt;br&gt;5min内完成的内务在不计时时为最高优先级" vertex="1">
