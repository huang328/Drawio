          <mxGeometry height="60" width="120" x="-450" y="1210" as="geometry" />
        </mxCell>
        <mxCell id="NTeQSQ7pl8E0C1H1Vsci-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;" value="恒生科技&lt;br&gt;允许周末放松日点30~40的外卖" vertex="1">
          <mxGeometry height="60" width="120" x="470" y="1360" as="geometry" />
        </mxCell>
        <mxCell id="EbW_i_ZtZpieSZF9_P0Z-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;碎片禁止&lt;br&gt;限制级应用在使用1小时后，必须在计时限制内使用&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="-450" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="PmbIQEbg_U_GPWdeKPpc-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;5.9失策原因&lt;br&gt;1.下班时间不定，回到宿舍在10~11点之间，而出门在8.15，项目紧迫使得晚上报复性玩和熬夜，平时最晚去到12点，周五1点，工作日限制&lt;br&gt;2.睡不足以及项目排期，导致早上没有静心学习的时间，而且国策树下午4点前在公司不浏览限制级软件也失败，习惯性在中午休息时间、等编译或claude code期间浏览限制级软件(b站、小红书)&lt;br&gt;3.睡前看蓝光电子产品，也影响了睡眠&lt;br&gt;4.每天懒于练习吉他，就一直没练，习惯的惯性&lt;br&gt;5.在工位上玩手机，破坏了神圣座位的习惯&lt;br&gt;6.懒于做每日计划，和收拾宿舍东西&lt;br&gt;7.刷牙洗脸不认真&lt;br&gt;&lt;br&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="270" width="290" x="-590" y="640" as="geometry" />
        </mxCell>
        <mxCell id="PmbIQEbg_U_GPWdeKPpc-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;" value="夜幕降临&lt;br&gt;23:00~8:00间电子产品设置成黑白" vertex="1">
          <mxGeometry height="60" width="120" x="60" y="170" as="geometry" />
        </mxCell>
        <mxCell id="ouI0tyibNmRItolM98-g-1" parent="1" style="swimlane;startSize=0;" value="" vertex="1">
